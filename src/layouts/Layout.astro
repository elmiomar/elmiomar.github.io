---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, LINKEDIN_URL, SITE_AUTHOR_EMAIL } from '../consts';

interface Props {
  title?: string;
  description?: string;
  pageType?: 'website' | 'article';
  pubDate?: Date;
  updatedDate?: Date;
  ogImage?: string;
}

const props = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead {...props} />
  </head>
  <body>
    <header class="site-header" data-pagefind-ignore="all">
      <div class="container">
        <a href="/" class="site-title">{SITE_TITLE}</a>
        <nav class="site-nav">
          <a href="/posts/">Posts</a>
          <a href="/about/">About</a>
          <a href="/resume/">Resume</a>
          <a href="/search/">Search</a>
          <span class="nav-icons">
            <a href="/rss.xml" title="RSS Feed" aria-label="RSS Feed">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
                ><circle cx="6.18" cy="17.82" r="2.18"
                ></circle><path
                  d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"
                ></path></svg>
            </a>
            <a href={LINKEDIN_URL} title="LinkedIn" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
                ><path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path></svg>
            </a>
          </span>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer" data-pagefind-ignore="all">
      <div class="container">
        <div class="footer-links">
          <a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <span class="dot">·</span>
          <a href={`mailto:${SITE_AUTHOR_EMAIL}`}>Email</a>
          <span class="dot">·</span>
          <a href="/rss.xml" target="_blank" rel="noopener noreferrer">RSS</a>
        </div>
      </div>
    </footer>

    <button class="theme-toggle" id="themeToggle" type="button" title="Toggle dark mode" aria-label="Toggle dark mode" aria-pressed="false">
      <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        ><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
      <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        ><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
    </button>

    <script>
      import '../scripts/theme-toggle.ts';
      import '../scripts/external-links.ts';
    </script>
  </body>
</html>
