---
import Layout from './Layout.astro';
import { formatDate } from '../utils/format-date';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  ogImage?: string;
  readingTimeMinutes?: number;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  ogImage,
  readingTimeMinutes,
} = Astro.props;
---

<Layout
  title={title}
  description={description}
  pageType="article"
  pubDate={pubDate}
  updatedDate={updatedDate}
  ogImage={ogImage}
>
  <a href="/posts/" class="all-posts-link">
    <svg width="16" height="16" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"
      ><path
        d="M14.19 16.005l7.869 7.868-2.129 2.129-9.996-9.997L19.937 6.002l2.127 2.129z"
      ></path></svg>
    All posts
  </a>

  <article class="article">
    <header class="article-header">
      <h1>{title}</h1>
      <p class="article-meta">
        {formatDate(pubDate)}
        {readingTimeMinutes ? ` · ${readingTimeMinutes} min read` : ''}
        {
          updatedDate && (
            <>
              {' · Updated '}
              {formatDate(updatedDate)}
            </>
          )
        }
      </p>
      {
        tags.length > 0 && (
          <div class="article-tags">
            {tags.map((tag) => (
              <a href={`/tags/#${tag.toLowerCase().replace(/\s+/g, '-')}`} class="tag">
                {tag}
              </a>
            ))}
          </div>
        )
      }
    </header>

    <div class="article-content">
      <slot />
    </div>
  </article>

  <button type="button" class="back-to-top" id="backToTop" title="Back to top" aria-label="Back to top">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
      ><polyline points="18 15 12 9 6 15"></polyline></svg>
  </button>

  <script>
    import '../scripts/back-to-top.ts';
  </script>
</Layout>
